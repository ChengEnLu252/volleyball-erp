# ============================================================
# 環境變數範本（此檔會提交；複製成 .env 後填真實值）
# .env 已 gitignore——所有敏感連線/密鑰只放 .env，不寫進程式碼。
# DB＝Supabase（雲端託管 Postgres）
# ============================================================

# ── Supabase 連線（兩條）────────────────────────────────────
# 來源：Supabase Dashboard → 右上「Connect」→「ORM」(Prisma) 分頁。
#  - DATABASE_URL：app 執行階段 → Transaction pooler(6543) + ?pgbouncer=true
#  - DIRECT_URL  ：prisma migrate/seed → Session pooler(5432)
# TODO[簽約後填真]：正式環境用對方的 Supabase 專案 / 自管 Postgres
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth v5)──────────────────────────────────
# 產生：openssl rand -base64 32
# TODO[簽約後填真]：正式環境用獨立強隨機值
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
