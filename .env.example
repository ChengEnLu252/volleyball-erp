# ============================================================
# 環境變數範本（此檔會提交；複製成 .env 後填真實值）
# .env 已 gitignore——所有敏感連線/密鑰只放 .env，不寫進程式碼。
# ============================================================

# ── 資料庫 ───────────────────────────────────────────────────
# 開發：本機 Docker Postgres（見 docker-compose.yml）
# 正式：P6 部署時換成正式主機連線字串
DATABASE_URL="postgresql://volleyops:volleyops_dev@localhost:5432/volleyops?schema=public"

# ── Auth.js (NextAuth v5) ───────────────────────────────────
# 產生方式：npx auto-secret 或 openssl rand -base64 32
# TODO[簽約後填真]：正式環境用獨立強隨機值，勿沿用開發值
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
