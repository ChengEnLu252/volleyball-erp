// ================================================================
// Prisma Schema — 排球場館管理系統
// 對應先前設計的 PostgreSQL schema
// 執行：npx prisma db push（開發）或 npx prisma migrate dev
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 球館 ──────────────────────────────────────────────────────────

model Venue {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  address   String?
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // 關聯
  userVenueRoles      UserVenueRole[]
  sessions            Session[]
  products            Product[]
  productTransactions ProductTransaction[]
  anomalyAlerts       AnomalyAlert[]

  @@map("venues")
}

// ── 系統使用者（操作人員）────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String     @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  phone        String?    @db.VarChar(20)
  passwordHash String     @map("password_hash")
  globalRole   GlobalRole @map("global_role")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  // 關聯
  venueRoles          UserVenueRole[]
  createdSessions     Session[]
  registeredBy        Registration[]
  recordedPayments    Payment[]
  productTransactions ProductTransaction[]
  auditLogs           AuditLog[]

  @@map("users")
}

enum GlobalRole {
  owner
  staff
}

// ── 使用者與球館角色對應 ──────────────────────────────────────────

model UserVenueRole {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  venueId   String    @map("venue_id")
  role      VenueRole
  createdAt DateTime  @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@map("user_venue_roles")
}

enum VenueRole {
  manager
  staff
}

// ── 客戶主檔 ──────────────────────────────────────────────────────

model Customer {
  id                  String      @id @default(uuid())
  name                String      @db.VarChar(100)
  phone               String?     @unique @db.VarChar(20)
  email               String?     @db.VarChar(255)
  skillLevel          SkillLevel? @map("skill_level")
  preferredNetHeight  String?     @map("preferred_net_height") @db.VarChar(20)
  notes               String?
  isBanned            Boolean     @default(false) @map("is_banned")
  createdAt           DateTime    @default(now()) @map("created_at")

  // 關聯
  registrations       Registration[]
  productTransactions ProductTransaction[]

  @@map("customers")
}

enum SkillLevel {
  beginner
  elementary
  intermediate
  advanced
  expert
}

// ── 場次 ──────────────────────────────────────────────────────────

model Session {
  id               String        @id @default(uuid())
  venueId          String        @map("venue_id")
  createdBy        String        @map("created_by")
  sessionDate      DateTime      @map("session_date") @db.Date
  startTime        String        @map("start_time") @db.VarChar(5)   // "09:00"
  endTime          String        @map("end_time") @db.VarChar(5)
  court            String?       @db.VarChar(50)
  netHeight        String        @map("net_height") @db.VarChar(20)
  sessionType      SessionType   @map("session_type")
  price            Int                                                // 元
  maxCapacity      Int           @map("max_capacity")
  minSkillRequired SkillLevel?   @map("min_skill_required")
  maxSkillAllowed  SkillLevel?   @map("max_skill_allowed")
  status           SessionStatus @default(open)
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // 關聯
  venue               Venue                @relation(fields: [venueId], references: [id])
  creator             User                 @relation(fields: [createdBy], references: [id])
  registrations       Registration[]
  productTransactions ProductTransaction[]

  @@index([venueId, sessionDate])
  @@map("sessions")
}

enum SessionType {
  beginner
  intermediate
  advanced
  mixed
}

enum SessionStatus {
  open
  full
  cancelled
  completed
}

// ── 報名 ──────────────────────────────────────────────────────────

model Registration {
  id           String             @id @default(uuid())
  sessionId    String             @map("session_id")
  customerId   String             @map("customer_id")
  registeredBy String             @map("registered_by")
  status       RegistrationStatus @default(registered)
  notes        String?
  registeredAt DateTime           @default(now()) @map("registered_at")

  // 關聯
  session  Session   @relation(fields: [sessionId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  operator User      @relation(fields: [registeredBy], references: [id])
  payments Payment[]

  @@unique([sessionId, customerId])
  @@index([sessionId])
  @@index([customerId])
  @@map("registrations")
}

enum RegistrationStatus {
  registered
  waitlist
  cancelled
  attended
}

// ── 付款記錄 ──────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  registrationId String        @map("registration_id")
  recordedBy     String        @map("recorded_by")
  amount         Int                          // 元
  method         PaymentMethod
  status         PaymentStatus @default(paid)
  notes          String?
  paidAt         DateTime      @default(now()) @map("paid_at")

  // 關聯
  registration Registration @relation(fields: [registrationId], references: [id])
  operator     User         @relation(fields: [recordedBy], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  cash
  transfer
  online
}

enum PaymentStatus {
  paid
  partial
  refunded
}

// ── 商品主檔 ──────────────────────────────────────────────────────

model Product {
  id                 String   @id @default(uuid())
  venueId            String?  @map("venue_id")   // null = 全館共用
  name               String   @db.VarChar(100)
  sku                String?  @db.VarChar(50)
  unitPrice          Int      @map("unit_price")
  currentStock       Int      @default(0) @map("current_stock")
  lowStockThreshold  Int      @default(5) @map("low_stock_threshold")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  // 關聯
  venue        Venue?               @relation(fields: [venueId], references: [id])
  transactions ProductTransaction[]

  @@map("products")
}

// ── 商品流向（販售 / 贈送 / 進貨 / 調整）────────────────────────

model ProductTransaction {
  id          String                 @id @default(uuid())
  productId   String                 @map("product_id")
  venueId     String                 @map("venue_id")
  operatedBy  String                 @map("operated_by")
  type        ProductTransactionType
  quantity    Int                    // 正數=增加，負數=減少
  unitPrice   Int?                   @map("unit_price")
  totalAmount Int?                   @map("total_amount")
  customerId  String?                @map("customer_id")
  sessionId   String?                @map("session_id")
  notes       String?
  operatedAt  DateTime               @default(now()) @map("operated_at")

  // 關聯
  product  Product   @relation(fields: [productId], references: [id])
  venue    Venue     @relation(fields: [venueId], references: [id])
  operator User      @relation(fields: [operatedBy], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  session  Session?  @relation(fields: [sessionId], references: [id])

  @@index([productId])
  @@index([venueId, operatedAt])
  @@map("product_transactions")
}

enum ProductTransactionType {
  purchase_in
  sale
  gift
  adjustment
}

// ── Audit Log ─────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  // 關聯
  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ── 異常警報 ──────────────────────────────────────────────────────

model AnomalyAlert {
  id        String     @id @default(uuid())
  venueId   String     @map("venue_id")
  type      AlertType
  level     AlertLevel
  message   String
  isRead    Boolean    @default(false) @map("is_read")
  createdAt DateTime   @default(now()) @map("created_at")

  // 關聯
  venue Venue @relation(fields: [venueId], references: [id])

  @@map("anomaly_alerts")
}

enum AlertType {
  gift_ratio
  revenue_drop
  low_stock
  unpaid
  registration_drop
}

enum AlertLevel {
  high
  medium
  low
}
