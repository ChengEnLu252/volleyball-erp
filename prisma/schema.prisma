// ================================================================
// Prisma Schema — 排球場館管理系統
// ----------------------------------------------------------------
// 此 schema 與 types/index.ts 完全對齊（截至 Milestone 1.4）。
// 兩者出現差異時，以 types/index.ts 為主 — 因為應用程式直接消費它。
//
// 何時更新此檔：階段 5+（接 PostgreSQL 的時候）。
// 階段 1-4 demo 期間，所有資料來源在 data/api.ts，並未使用 prisma。
//
// 執行：npx prisma db push（開發）或 npx prisma migrate dev
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // app 執行階段：走 Supabase pooled 連線（Supavisor，transaction mode, port 6543）
  url       = env("DATABASE_URL")
  // migrate / introspect：走 direct 連線（session mode, port 5432）
  // — pooled 連線不支援 migration 需要的 prepared statements / DDL
  directUrl = env("DIRECT_URL")
}


// ================================================================
// 一、基礎主檔
// ================================================================

// ── 球館 ──────────────────────────────────────────────────────────

model Venue {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  address   String?
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // 關聯
  userVenueRoles      UserVenueRole[]
  timeslots           Timeslot[]
  sessions            Session[]
  products            Product[]
  productTransactions ProductTransaction[]
  anomalyAlerts       AnomalyAlert[]
  ledgerDays          LedgerDay[]
  partTimerSheets     PartTimerSheet[]
  managerSalaries     ManagerSalary[]

  @@map("venues")
}


// ── 系統使用者（操作人員）─────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String     @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  /// 登入代號（Auth.js 帳號）。可空 unique 以便對既有列加欄位；簽約後收緊為 NOT NULL
  username     String?    @unique @db.VarChar(50)
  phone        String?    @db.VarChar(20)
  passwordHash String     @map("password_hash")
  globalRole   GlobalRole @map("global_role")
  /// 自助註冊審核狀態。owner/既有帳號為 approved；新註冊者預設 pending，
  /// 需 owner 審核通過才能登入（見 auth.ts authorize 與審核頁）
  approvalStatus ApprovalStatus @default(pending) @map("approval_status")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  // 關聯
  venueRoles          UserVenueRole[]
  createdSessions     Session[]
  registeredBy        Registration[]
  recordedPayments    Payment[]
  productTransactions ProductTransaction[]
  auditLogs           AuditLog[]
  ledgerDays          LedgerDay[]
  partTimerSheets     PartTimerSheet[]
  managerSalaries     ManagerSalary[]

  @@map("users")
}

enum GlobalRole {
  owner
  staff
}

/// 帳號審核狀態（自助註冊用）
enum ApprovalStatus {
  pending
  approved
  rejected
}


// ── 使用者與球館角色對應 ──────────────────────────────────────────

model UserVenueRole {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  venueId   String    @map("venue_id")
  role      VenueRole
  createdAt DateTime  @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@map("user_venue_roles")
}

enum VenueRole {
  manager
  staff
}


// ── 客戶主檔 ──────────────────────────────────────────────────────

model Customer {
  id                 String      @id @default(uuid())
  name               String      @db.VarChar(100)
  // 電話不再唯一：允許「同號碼新增為不同人」（報名自助建檔的三選一之一）
  phone              String?     @db.VarChar(20)
  email              String?     @db.VarChar(255)
  skillLevel         SkillLevel? @map("skill_level")
  preferredNetHeight NetHeight?  @map("preferred_net_height")
  gender             Gender?
  notes              String?
  isBanned           Boolean     @default(false) @map("is_banned")
  createdAt          DateTime    @default(now()) @map("created_at")

  // 關聯
  registrations       Registration[]
  productTransactions ProductTransaction[]
  /** 此客戶擔任主揪的所有季租單 */
  captainSeasonRentals SeasonRental[]

  @@map("customers")
}

/// 排球程度評級。
/// + 與 * 在 PostgreSQL enum 中不合法，所以用底線版本，
/// 透過 @map 對應到實際儲存值。
enum SkillLevel {
  E
  D
  C
  B
  B_PLUS @map("B+")
  A
  A_PLUS @map("A+")
  S
  S_STAR @map("S*")
}

/// 網高 — 男網/女網/可調式
enum NetHeight {
  female
  male
  adjustable
}

/// 性別 — 報名自助建檔用（male 男 / female 女 / undisclosed 不透露）
enum Gender {
  male
  female
  undisclosed
}


// ================================================================
// 二、季制相關（階段 1.1 新增）
// ================================================================

// ── 季 ───────────────────────────────────────────────────────────
// 12 週為一單位的營運區段。同時間應只有一個 isActive=true 的 Season。

model Season {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)               // 例：「2026 春季」
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  numWeeks  Int      @default(12) @map("num_weeks")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // 關聯
  seasonRentals SeasonRental[]

  @@map("seasons")
}


// ── 時段 ─────────────────────────────────────────────────────────
// 每週重複的某時段（例：飛翼週四 14-17）。
// 一個 Timeslot 在 Season 期間會產生 numWeeks 個 Session 實例。

model Timeslot {
  id                      String      @id @default(uuid())
  venueId                 String      @map("venue_id")
  label                   String?     @db.VarChar(100)               // 例：「週四晚黃金場」
  /// 0=週日、1=週一、... 6=週六（與 JS Date.getDay() 一致）
  dayOfWeek               Int         @map("day_of_week")
  startTime               String      @map("start_time") @db.VarChar(5)   // "14:00"
  endTime                 String      @map("end_time") @db.VarChar(5)
  court                   String?     @db.VarChar(50)
  defaultNetHeight        NetHeight   @map("default_net_height")
  defaultSessionType      SessionType @map("default_session_type")
  defaultMinSkillRequired SkillLevel? @map("default_min_skill_required")
  defaultMaxSkillAllowed  SkillLevel? @map("default_max_skill_allowed")
  defaultMaxCapacity      Int         @default(18) @map("default_max_capacity")
  /// 預設球費（元）— 建立 Session 時複製到 Session.courtFee。
  /// 冷氣費沒有預設值，必須每場手動輸入。
  defaultCourtFee         Int         @map("default_court_fee")
  /// 由老闆手動標記是否為熱門時段（影響館長績效計算）
  isHotZone               Boolean     @default(false) @map("is_hot_zone")
  isActive                Boolean     @default(true) @map("is_active")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  // 關聯
  venue          Venue          @relation(fields: [venueId], references: [id])
  sessions       Session[]
  seasonRentals  SeasonRental[]

  @@index([venueId, dayOfWeek])
  @@map("timeslots")
}


// ── 季租單 ───────────────────────────────────────────────────────
// 主揪（= 某 Customer）季初一次性包下某 Timeslot 整季 18 人份的承諾。
// 主揪不是 User／不在權限系統內，僅靠 accessToken 取得有限存取。

model SeasonRental {
  id                   String              @id @default(uuid())
  timeslotId           String              @map("timeslot_id")
  seasonId             String              @map("season_id")
  /// 主揪 = 某 Customer 的 id。不在 User 表，故指向 Customer。
  captainId            String              @map("captain_id")
  /// 每場應收（元）— 通常 = courtFee × 18。建立時鎖定。
  pricePerSession      Int                 @map("price_per_session")
  /// 季初一次性應收（元）= pricePerSession × 預期場次數
  totalAmount          Int                 @map("total_amount")
  /// 主揪實際繳交給館方的金額（理想 = totalAmount）
  paidAmount           Int                 @default(0) @map("paid_amount")
  /// 主揪登入用的一次性 token；過期後失效
  accessToken          String              @unique @map("access_token") @db.VarChar(64)
  accessTokenExpiresAt DateTime            @map("access_token_expires_at")
  status               SeasonRentalStatus  @default(pending)
  notes                String?
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  // 關聯
  timeslot Timeslot  @relation(fields: [timeslotId], references: [id])
  season   Season    @relation(fields: [seasonId], references: [id])
  captain  Customer  @relation(fields: [captainId], references: [id])
  sessions Session[]

  @@index([timeslotId, seasonId])
  @@index([captainId])
  @@map("season_rentals")
}

enum SeasonRentalStatus {
  pending
  active
  completed
  cancelled
}


// ================================================================
// 三、場次與報名
// ================================================================

// ── 場次 ─────────────────────────────────────────────────────────

model Session {
  id               String        @id @default(uuid())
  venueId          String        @map("venue_id")
  /// 母時段 — 有值表示是 Timeslot 的某週實例；null 表示臨時加開
  timeslotId       String?       @map("timeslot_id")
  /// 對應的季租單 — 有值表示季打人員不另外付費
  seasonRentalId   String?       @map("season_rental_id")
  createdBy        String        @map("created_by")
  sessionDate      DateTime      @map("session_date") @db.Date
  startTime        String        @map("start_time") @db.VarChar(5)   // "09:00"
  endTime          String        @map("end_time") @db.VarChar(5)
  court            String?       @db.VarChar(50)
  netHeight        NetHeight     @map("net_height")
  sessionType      SessionType   @map("session_type")
  /// 球費（元）— 每位臨打應收的基本費用。季打人員不付（已於季初收齊）
  courtFee         Int           @map("court_fee")
  /// 冷氣費（元）— 若 acEnabled=true，每位臨打額外應收。
  /// 無預設值，由開場員每場手動輸入（避免「習慣性收費」）
  acFee            Int           @default(0) @map("ac_fee")
  /// 此場是否實際開冷氣
  acEnabled        Boolean       @default(false) @map("ac_enabled")
  maxCapacity      Int           @map("max_capacity")
  minSkillRequired SkillLevel?   @map("min_skill_required")
  maxSkillAllowed  SkillLevel?   @map("max_skill_allowed")
  status           SessionStatus @default(open)
  /// 無人場次（無工讀生駐場）— 客戶必須線上報名 + 自助回報已付款
  isUnattended     Boolean       @default(false) @map("is_unattended")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // 關聯
  venue               Venue                @relation(fields: [venueId], references: [id])
  timeslot            Timeslot?            @relation(fields: [timeslotId], references: [id])
  seasonRental        SeasonRental?        @relation(fields: [seasonRentalId], references: [id])
  creator             User                 @relation(fields: [createdBy], references: [id])
  registrations       Registration[]
  productTransactions ProductTransaction[]

  @@index([venueId, sessionDate])
  @@index([timeslotId])
  @@index([seasonRentalId])
  @@map("sessions")
}

/// 場次類型 — 男網/女網 + 純男/混排/專位 + 包場
enum SessionType {
  male_only
  male_mixed
  male_position
  female_only
  female_mixed
  female_position
  rental
}

enum SessionStatus {
  open
  full
  cancelled
  completed
}


// ── 報名 ─────────────────────────────────────────────────────────

model Registration {
  id                  String              @id @default(uuid())
  sessionId           String              @map("session_id")
  customerId          String              @map("customer_id")
  /// 報名類型 — 影響應收金額計算
  type                RegistrationType
  /// 操作員 — null 表示由 captain 或 self 建立（搭配 registeredBySource 識別）
  registeredBy        String?             @map("registered_by")
  /// 來源 — 區分「館長/工讀生」、「主揪」、「客戶自助」
  registeredBySource  RegistrationSource  @map("registered_by_source")
  status              RegistrationStatus  @default(registered)
  notes               String?
  registeredAt        DateTime            @default(now()) @map("registered_at")
  /// 樂觀鎖用：每次 update 自動 bump（主揪/工讀生同時編輯時偵測衝突）
  updatedAt           DateTime            @updatedAt @map("updated_at")

  // ── 自助回報付款（僅無人場次使用）──────────────────────────
  /// 客戶在系統按下「我已付款」
  selfReportedPaid    Boolean             @default(false) @map("self_reported_paid")
  /// 自助付款方式（cash 投錢箱 / transfer 轉帳 / online 線上付款）
  selfPaymentMethod   PaymentMethod?      @map("self_payment_method")
  /// 自助付款憑證 URL 或檔名（轉帳必填，投錢箱通常 null）
  selfPaymentEvidence String?             @map("self_payment_evidence")
  selfReportedAt      DateTime?           @map("self_reported_at")

  // ── 退費決策（P2.1d；場次取消後對已付款報名）──────────────
  /// null=未決定（出現在待退費清單）；refunded=已開負額 Payment；waived=放棄退費
  /// 退費後設資料（金額/方式/原因/誰/何時）由負額 Payment + AuditLog 推導，不另存欄位
  refundDecision      RefundDecision?     @map("refund_decision")

  // 關聯
  session  Session   @relation(fields: [sessionId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  operator User?     @relation(fields: [registeredBy], references: [id])
  payments Payment[]

  @@unique([sessionId, customerId])
  @@index([sessionId])
  @@index([customerId])
  @@map("registrations")
}

enum RegistrationStatus {
  registered
  waitlist
  cancelled
  attended
}

/// 報名類型
/// - season_player：在 SeasonRental 範圍內（不另外收費）
/// - season_substitute：季打請假時的補位（要付費）
/// - walk_in：散客（要付費）
enum RegistrationType {
  season_player
  season_substitute
  walk_in
}

/// 報名來源
/// - staff：館長 / 工讀生代為報名
/// - captain：主揪用 token 加入臨打
/// - self：客戶在無人場次自助報名
enum RegistrationSource {
  staff
  captain
  self
}

/// 退費決策（P2.1d）
enum RefundDecision {
  refunded
  waived
}


// ── 付款記錄 ─────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  registrationId String        @map("registration_id")
  recordedBy     String        @map("recorded_by")
  amount         Int                          // 元
  method         PaymentMethod
  status         PaymentStatus @default(paid)
  notes          String?
  paidAt         DateTime      @default(now()) @map("paid_at")

  // 關聯
  registration Registration @relation(fields: [registrationId], references: [id])
  operator     User         @relation(fields: [recordedBy], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  cash
  transfer
  online
}

enum PaymentStatus {
  paid
  partial
  refunded
  unpaid
}


// ================================================================
// 四、商品與庫存
// ================================================================

// ── 商品主檔 ─────────────────────────────────────────────────────

model Product {
  id                String   @id @default(uuid())
  /// null = 全館共用；有值 = 該館限定
  venueId           String?  @map("venue_id")
  name              String   @db.VarChar(100)
  sku               String?  @db.VarChar(50)
  unitPrice         Int      @map("unit_price")
  currentStock      Int      @default(0) @map("current_stock")
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  // 關聯
  venue        Venue?               @relation(fields: [venueId], references: [id])
  transactions ProductTransaction[]

  @@map("products")
}


// ── 商品流向（販售 / 贈送 / 進貨 / 調整）──────────────────────────

model ProductTransaction {
  id          String                 @id @default(uuid())
  productId   String                 @map("product_id")
  venueId     String                 @map("venue_id")
  operatedBy  String                 @map("operated_by")
  type        ProductTransactionType
  /// 正數=增加，負數=減少
  quantity    Int
  unitPrice   Int?                   @map("unit_price")
  totalAmount Int?                   @map("total_amount")
  customerId  String?                @map("customer_id")
  sessionId   String?                @map("session_id")
  notes       String?
  operatedAt  DateTime               @default(now()) @map("operated_at")

  // 關聯
  product  Product   @relation(fields: [productId], references: [id])
  venue    Venue     @relation(fields: [venueId], references: [id])
  operator User      @relation(fields: [operatedBy], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  session  Session?  @relation(fields: [sessionId], references: [id])

  @@index([productId])
  @@index([venueId, operatedAt])
  @@map("product_transactions")
}

enum ProductTransactionType {
  purchase_in
  sale
  gift
  adjustment
}


// ================================================================
// 五、系統表
// ================================================================

// ── Audit Log ────────────────────────────────────────────────────
// 系統內所有關鍵動作的稽核軌跡。

model AuditLog {
  id         String      @id @default(uuid())
  /// 主揪 / 自助操作時 userId 可為 null，從 newValues 找出實際操作者
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  createdAt  DateTime    @default(now()) @map("created_at")

  // 關聯
  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum AuditAction {
  // 既有
  CREATE_REGISTRATION
  CANCEL_REGISTRATION
  UPDATE_PAYMENT
  ADD_PAYMENT
  ADD_PRODUCT_SALE
  ADD_PRODUCT_GIFT
  ADJUST_STOCK
  CREATE_SESSION
  UPDATE_SESSION
  CANCEL_SESSION
  // 階段 1.1 新增：主揪相關
  CAPTAIN_LOGIN
  MARK_ATTENDANCE_BY_CAPTAIN
  ADD_WALKIN_BY_CAPTAIN
  // 階段 1.1 新增：自助回報
  SELF_PAYMENT_REPORT
  // 階段 1.1 新增：季租單
  CREATE_SEASON_RENTAL
  UPDATE_SEASON_RENTAL
  CANCEL_SEASON_RENTAL
  // P2.1d 新增：退費鏈
  ISSUE_REFUND
  WAIVE_REFUND
  // P2.2d 新增：月記帳
  UPSERT_LEDGER
  // P2.3c 新增：館長週目標
  CREATE_WEEKLY_GOAL
  SUBMIT_WEEKLY_GOAL
  CONFIRM_WEEKLY_GOAL
  RETURN_WEEKLY_GOAL
}


// ── 異常警報 ─────────────────────────────────────────────────────

model AnomalyAlert {
  id        String         @id @default(uuid())
  venueId   String         @map("venue_id")
  type      AlertType
  severity  AlertSeverity
  message   String
  isRead    Boolean        @default(false) @map("is_read")
  createdAt DateTime       @default(now()) @map("created_at")

  // 關聯
  venue Venue @relation(fields: [venueId], references: [id])

  @@map("anomaly_alerts")
}

enum AlertType {
  gift_ratio
  revenue_drop
  low_stock
  unpaid_excess
  signup_drop
}

enum AlertSeverity {
  warning
  critical
}


// ── 月記帳（P2.2d）─────────────────────────────────────────────
// 對應對方 Excel「多爾森記帳表」：館長每日記帳，一館一天一筆。
// slots = 各時段場地費（金額或「包場/季租」字串註記）；其餘為當日各類銷售/收費。
// 老闆對帳（review）把這些數字與系統既有資料（Payment/ProductTransaction）比差異。

model LedgerDay {
  id            String   @id @default(uuid())
  venueId       String   @map("venue_id")
  /// 記帳日（一館一天唯一）
  date          DateTime @db.Date
  /// 各時段場地費：key=時段 key（見 data/ledger-core LEDGER_SLOTS），value=金額(number) 或 註記(string)
  slots         Json     @default("{}")

  // ── 銷售類別 ──
  merch         Int      @default(0)
  snacks        Int      @default(0)
  drinks        Int      @default(0)
  ac            Int      @default(0)
  other         Int      @default(0)

  // ── 收費 / 退款 ──
  seasonFee     Int      @default(0) @map("season_fee")
  privatePrepay Int      @default(0) @map("private_prepay")
  acFee         Int      @default(0) @map("ac_fee")
  refund        Int      @default(0)

  // ── 冷氣度數（試算 = 度數 × 單價）──
  acDegrees     Int      @default(0) @map("ac_degrees")

  // ── 文字明細 ──
  bookingNote   String   @default("") @map("booking_note")
  refundNote    String   @default("") @map("refund_note")
  merchNote     String   @default("") @map("merch_note")

  reported      Boolean  @default(false)
  updatedBy     String   @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  venue   Venue @relation(fields: [venueId], references: [id])
  updater User  @relation(fields: [updatedBy], references: [id])

  @@unique([venueId, date])
  @@index([venueId, date])
  @@map("ledger_days")
}


// ── 工讀生時薪表（P2.3a）───────────────────────────────────────
// 每館每月一張。rows = PartTimerRow[]（姓名/等級/時薪/時數/獎金/罰款/備註）以 JSON 存。
// 計算（正常薪水/總薪水/薪資比例）由 data/payroll-core 即時算、不存。

model PartTimerSheet {
  id              String   @id @default(uuid())
  venueId         String   @map("venue_id")
  /// 月份 YYYY-MM
  month           String   @db.VarChar(7)
  /// PartTimerRow[]（JSON）
  rows            Json     @default("[]")
  /// 本月營收人工覆寫；null = 用系統值（薪資比例分母）
  revenueOverride Int?     @map("revenue_override")
  updatedBy       String   @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")

  venue   Venue @relation(fields: [venueId], references: [id])
  updater User  @relation(fields: [updatedBy], references: [id])

  @@unique([venueId, month])
  @@index([venueId, month])
  @@map("part_timer_sheets")
}


// ── 管理職薪資（P2.3b）─────────────────────────────────────────
// 每人每月一筆（一館一月可多人）。bonuses/deductions = ManagerLineItem[]（JSON）。
// 結算（含冷門場次獎金/分潤、請假扣薪）由 data/payroll-core 即時算、不存。
// id 由 client 提供（`${venueId}:${month}:slug`），upsert by id。

model ManagerSalary {
  id                  String   @id
  venueId             String   @map("venue_id")
  month               String   @db.VarChar(7)
  personName          String   @map("person_name")
  baseSalary          Int      @default(0) @map("base_salary")
  designPay           Int      @default(0) @map("design_pay")
  /// ManagerLineItem[]（JSON）：額外獎金
  bonuses             Json     @default("[]")
  includeOffPeakBonus Boolean  @default(true) @map("include_off_peak_bonus")
  insuranceSelf       Int      @default(0) @map("insurance_self")
  leaveDays           Int      @default(0) @map("leave_days")
  /// ManagerLineItem[]（JSON）：其他扣款
  deductions          Json     @default("[]")
  updatedBy           String   @map("updated_by")
  updatedAt           DateTime @updatedAt @map("updated_at")

  venue   Venue @relation(fields: [venueId], references: [id])
  updater User  @relation(fields: [updatedBy], references: [id])

  @@index([venueId, month])
  @@map("manager_salaries")
}


// ── 館長週目標 + 通知（P2.3c）──────────────────────────────────
// 工作流：assigned →（館長上傳截圖）→ submitted →（老闆）→ confirmed / returned。
// evidenceId 引用既有上傳機制（截圖實體存物件儲存留 P4）。
// user/venue 以 id 字串引用（不設 FK，沿用 demo 慣例、減少 back-relation）。

enum WeeklyGoalStatus {
  assigned
  submitted
  confirmed
  returned
}

enum WeeklyGoalSource {
  owner_assigned
  manager_self
}

enum NotificationType {
  goal_submitted
  goal_confirmed
  goal_returned
  order_placed
}

model WeeklyGoal {
  id           String           @id @default(uuid())
  venueId      String           @map("venue_id")
  /// 該週週一（YYYY-MM-DD）
  weekStart    DateTime         @db.Date @map("week_start")
  description  String
  source       WeeklyGoalSource
  createdBy    String           @map("created_by")
  status       WeeklyGoalStatus @default(assigned)
  /// 完成截圖引用（實體存物件儲存留 P4）；未上傳為 null
  evidenceId   String?          @map("evidence_id")
  submittedBy  String?          @map("submitted_by")
  submittedAt  DateTime?        @map("submitted_at")
  confirmedBy  String?          @map("confirmed_by")
  confirmedAt  DateTime?        @map("confirmed_at")
  returnReason String?          @map("return_reason")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([venueId, weekStart])
  @@map("weekly_goals")
}

model AppNotification {
  id              String           @id @default(uuid())
  type            NotificationType
  recipientUserId String           @map("recipient_user_id")
  title           String
  body            String
  linkHref        String?          @map("link_href")
  relatedType     String?          @map("related_type")
  relatedId       String?          @map("related_id")
  isRead          Boolean          @default(false) @map("is_read")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([recipientUserId, isRead])
  @@map("app_notifications")
}
